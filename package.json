{
  "name": "light-runner",
  "version": "0.10.0",
  "description": "Run isolated Docker containers from Node.js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/*.js",
    "dist/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs');try{for(const f of fs.readdirSync('dist')){fs.rmSync('dist/'+f,{recursive:true,force:true})}}catch(e){if(e.code!=='ENOENT')throw e}\"",
    "build": "npm run clean && tsc",
    "dev": "tsc --watch",
    "test": "node --test \"dist/test/**/*.test.js\"",
    "test:unit": "node --test \"dist/test/unit/*.test.js\"",
    "test:e2e": "node --test \"dist/test/e2e/*.test.js\"",
    "test:build": "npm run clean && tsc -p tsconfig.test.json",
    "test:all": "npm run test:build && npm test",
    "test:docker": "docker compose -f docker-compose.test.yml run --rm --build test",
    "demo": "npm run test:build && node dist/examples/main.js",
    "demo:detached": "npm run test:build && node dist/examples/detached-full.js",
    "docs": "npm run docs:typedoc && npm run docs:build",
    "preversion": "npm run docs && git add docs/api/",
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "docs:typedoc": "node -e \"require('node:fs').rmSync('docs/api',{recursive:true,force:true})\" && typedoc",
    "docs:dev": "npm run docs:typedoc && vitepress dev docs",
    "docs:build": "vitepress build docs"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "docker",
    "sandbox",
    "container",
    "runner",
    "isolation"
  ],
  "license": "MIT",
  "repository": "github:enixCode/light-runner",
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "dockerode": "^5.0.0",
    "tar": "^7.5.13"
  }
}
